# .env.test.example
# Copy this file to .env.test and fill in your test Supabase project credentials.
# NEVER commit .env.test — it contains real credentials.

# Supabase test project (separate from dev — create at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-test-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key

# Test user — create this user manually in the Supabase test project dashboard
PLAYWRIGHT_TEST_EMAIL=testplayer@example.com
PLAYWRIGHT_TEST_PASSWORD=TestPassword123!

# Base URL for the running app (used by Playwright)
PLAYWRIGHT_BASE_URL=http://localhost:3000
