# -----------------------------------------------------------------------
# Volleyball Game Reservation — Environment Variables
# -----------------------------------------------------------------------
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# -----------------------------------------------------------------------

# Supabase project URL (safe to expose — required on client and server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (safe to expose — scoped by RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SECRET, server-side only, bypasses RLS.
# Used in src/lib/supabase/service.ts for admin operations.
# Never prefix with NEXT_PUBLIC_; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
